# Vite exposes variables prefixed with VITE_ or REACT_APP_ to the client at build time.
# Include the /api path suffix. Rebuild the app after changing these values.

# Preferred (Vite)
VITE_API_URL=http://localhost:5000/api

# Legacy aliases (still supported)
# VITE_API_BASE_URL=http://localhost:5000/api
# REACT_APP_API_URL=http://localhost:5000/api
