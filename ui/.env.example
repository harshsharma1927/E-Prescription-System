# Vite exposes variables prefixed with VITE_ or REACT_APP_ to the client at build time.
# Include the /api path suffix. Restart dev server or rebuild after changing these values.

# Local backend (default for development)
VITE_API_URL=http://localhost:5000/api

# Deployed backend (Render) — use for Vercel or when testing against production API
# VITE_API_URL=https://e-prescript.onrender.com/api

# Legacy aliases (still supported)
# VITE_API_BASE_URL=https://e-prescript.onrender.com/api
# REACT_APP_API_URL=https://e-prescript.onrender.com/api
